{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["../node_modules/@types"],
    "types": ["react", "react-dom"],
    "noEmit": true,
    "baseUrl": ".."
  },
  "include": ["src", "vite.config.ts"]
}
